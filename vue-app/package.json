{
  "name": "sgummalla-works",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @sgw/server dev",
    "build": "pnpm --filter @sgw/ui build && pnpm --filter @sgw/client build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,vue,css,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,vue,css,json,md}\"",
    "check": "pnpm --filter @sgw/ui build && pnpm --filter @sgw/ui exec vue-tsc --noEmit && pnpm --filter @sgw/client exec vue-tsc --noEmit && pnpm --filter @sgw/server exec tsc --noEmit && pnpm format:check && pnpm --filter @sgw/client exec vite build"
  },
  "devDependencies": {
    "@prettier/plugin-xml": "^3.4.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.24.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.0"
  }
}
