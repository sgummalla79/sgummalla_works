{
  "name": "@sgw/ui",
  "version": "0.1.0",
  "private": false,
  "description": "Sgummalla Works shared UI component library",
  "type": "module",
  "main": "./dist/sgw-ui.umd.cjs",
  "module": "./dist/sgw-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/sgw-ui.js",
      "require": "./dist/sgw-ui.umd.cjs"
    },
    "./styles": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && vue-tsc --project tsconfig.build.json",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src --ext .ts,.vue"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/tsconfig": "^0.5.0",
    "unocss": "^0.59.0",
    "vite": "^5.2.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  },
  "dependencies": {
    "vue-router": "^4.6.4"
  }
}
