# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Set in production to redirect all non-canonical hostnames (e.g. fly.dev) to this domain
# CANONICAL_HOST=sgummallaworks.com

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=1h
JWT_COOKIE_NAME=sgw_token

# ── Auth0 ────────────────────────────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_CALLBACK_URL=http://localhost:3000/api/auth0/callback

# ── SAML ─────────────────────────────────────────────────────────────────────
SAML_CALLBACK_URL=http://localhost:3000/api/saml/callback
SAML_ENTRY_POINT=
SAML_ISSUER=
SAML_CERT=

# ── OIDC ─────────────────────────────────────────────────────────────────────
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# ── Credential Auth (temporary — replace with DB lookup in production) ────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# ── Owner ────────────────────────────────────────────────────────────────────
OWNER_USER_ID=auth0|your-user-id

# ── Fly.io (usage dashboard) ──────────────────────────────────────────────────
# Token: run `fly tokens create readonly`
FLY_ORG_SLUG=suman-gummalla
FLY_APP_NAME=sgummalla-net
FLY_API_TOKEN=

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=debug
