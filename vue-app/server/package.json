{
  "name": "@sgw/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --ignore '../client/**/*.timestamp*' src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "migrate:logs": "tsx src/scripts/migrateLogsToSingle.ts"
  },
  "dependencies": {
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-openid-connect": "^2.17.1",
    "firebase-admin": "^13.8.0",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.2",
    "openid-client": "^5.6.5",
    "passport": "^0.7.0",
    "passport-saml": "^3.2.4",
    "postgres": "^3.4.9",
    "tsx": "^4.7.2",
    "xml-crypto": "^6.1.2"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.0",
    "@types/passport": "^1.0.16",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  }
}
