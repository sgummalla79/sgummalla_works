{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "paths": { "@/*": ["./src/*"] },
    "types": ["vite/client"]
  },
  "vueCompilerOptions": {
    "target": 3.4
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "src/**/*.d.ts", "env.d.ts"],
  "exclude": ["node_modules", "dist"]
}
